# ══════════════════════════════════════════
# SafeSync Backend — 환경변수 설정
# 실제 배포 시 이 파일을 수정하세요
# ══════════════════════════════════════════

# ── 앱 설정 ──
APP_NAME=SafeSync
APP_ENV=development          # development | production
DEBUG=true
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── 데이터베이스 (NCP Cloud DB / AWS RDS) ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=safesync
DB_USER=safesync_user
DB_PASSWORD=your_db_password_here
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── CLOVA Studio API ──
# NCP 콘솔 > AI·NAVER API > CLOVA Studio 에서 발급
CLOVA_STUDIO_API_KEY=your_clova_studio_api_key_here
CLOVA_STUDIO_APIGW_URL=https://clovastudio.stream.ntruss.com
CLOVA_STUDIO_REQUEST_ID=your_request_id_here

# ── JWT 인증 ──
JWT_SECRET_KEY=change_this_to_very_long_random_secret_key_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── 관리자 계정 (초기값, 추후 DB로 이관 권장) ──
ADMIN_ID=admin
ADMIN_PASSWORD=safesync2024

# ── NCP Object Storage (이미지 업로드) ──
NCP_ACCESS_KEY=your_ncp_access_key
NCP_SECRET_KEY=your_ncp_secret_key
NCP_ENDPOINT=https://kr.object.ncloudstorage.com
NCP_BUCKET=safesync-images

# ── 클라우드 구분 (어느 클라우드에 배포됐는지 표시) ──
CLOUD_PROVIDER=NCP        # NCP | AWS
CLOUD_REGION=KR-1
